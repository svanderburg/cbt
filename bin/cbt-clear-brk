#!/bin/bash -e

# Open functionality modules
source $CBT_DATADIR/lib/checks
source $CBT_DATADIR/lib/break

# Shows the usage of this command to the user

showUsage()
{
    local me="$(basename "$0")"

    cat <<EOF
Usage: $me SEQUENCE

Clears the breakpoint set on a given sequence.

Options:
  -h, --help             Display help page
  -v, --version          Display version

Environment:
  TMPDIR                 Directory where temp files should be stored (default:
                         /tmp)
EOF
}

# Shows the version of this command to the user

showVersion()
{
    local me="$(basename "$0")"

    cat <<EOF
$me (cbt) 0.1
EOF
}

# Parse valid argument options

PARAMS=`getopt -n "$0" -o hv -l help,version -- "$@"`

if [ $? != 0 ]
then
     showUsage
     exit 1
fi

eval set -- "$PARAMS"

# Evaluate valid options

while [ "$1" != "--" ]
do
    case "$1" in
        -h|--help)
            showUsage
            exit 0
            ;;
        -v|--version)
            showVersion
            exit 0
            ;;
        *)
            showUsage
            exit 1
            ;;
    esac

    shift
done

shift

# Evaluate non-options

if [ "$1" = "" ]
then
    echo "No sequence specified"
    showUsage
    exit 1
else
    sequenceName="$(basename "$1")"
fi

# Evaluate environment variables
checkCbtStateDir

# Clear break point
clearBreakPoint "$sequenceName"
